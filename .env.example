# Helm Agent Control — Environment Variables
# Copy this file to .env and fill in values for CLI mode.
# When using the VS Code extension with Copilot, NO keys are needed —
# the extension routes all model calls through vscode.lm automatically.

# ---------------------------------------------------------------------------
# Anthropic (Claude) — used when models.yaml assigns sonnet-4.6 / haiku-4.6
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the resolved Anthropic model IDs
# HELM_ANTHROPIC_MODEL_SONNET46=claude-sonnet-4-6
# HELM_ANTHROPIC_MODEL_HAIKU46=claude-haiku-4-6

# ---------------------------------------------------------------------------
# OpenAI — used when models.yaml assigns a gpt-* alias
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional: override the resolved OpenAI model ID
# HELM_OPENAI_MODEL_GPT54=gpt-4o

# ---------------------------------------------------------------------------
# Google — used when models.yaml assigns a gemini-* alias
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=AIza...

# Optional: override the resolved Gemini model ID
# HELM_GOOGLE_MODEL_GEMINI=gemini-1.5-pro

# ---------------------------------------------------------------------------
# Development / testing
# ---------------------------------------------------------------------------
# Set to "true" to run all stages with the mock adapter (no API calls made)
# HELM_MOCK_MODE=true
